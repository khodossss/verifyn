# ── LLM Provider ──────────────────────────────────────────────────────────────
# Supported: openai (default), anthropic, ollama
LLM_PROVIDER=openai

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-nano-2025-08-07

# Anthropic (optional) — https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (optional) — https://ollama.ai
# OLLAMA_MODEL=llama3.1
# OLLAMA_BASE_URL=http://localhost:11434

# Tavily — https://app.tavily.com (free: 1000 req/month)
# Set TAVILY_USE=false to use DuckDuckGo instead (no API key needed)
TAVILY_USE=true
TAVILY_API_KEY=tvly-...

# LangSmith — https://smith.langchain.com (optional, enables tracing)
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=verifyn

# ── Embeddings (similarity search) ────────────────────────────────────────────
# Provider: openai (default), ollama, custom
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Ollama embeddings — local, free, no API key
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# Models: nomic-embed-text, mxbai-embed-large, snowflake-arctic-embed
# Requires: ollama pull nomic-embed-text

# Custom OpenAI-compatible endpoint (vLLM, LiteLLM, HuggingFace TEI, etc.)
# EMBEDDING_PROVIDER=custom
# EMBEDDING_BASE_URL=http://localhost:8080/v1
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# EMBEDDING_API_KEY=your-key-if-needed

# Similarity threshold — minimum cosine similarity to consider a match (0.0-1.0)
SIMILARITY_THRESHOLD=0.75

# ── Claim detector pre-filter ─────────────────────────────────────────────────
CLAIM_DETECTOR_ENABLED=true
CLAIM_SCORE_THRESHOLD=0.015

# ── Database ──────────────────────────────────────────────────────────────────
# Domain reputation + query history with embeddings
# PostgreSQL: postgresql://user:pass@localhost:5432/verifyn
# SQLite (default, zero-config): sqlite:///data/verifyn.db
DATABASE_URL=sqlite:///data/verifyn.db
CREDIBILITY_THRESHOLD=50

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Network (Docker Compose) ───────────────────────────────────────────────────
# Backend: 127.0.0.1 = local-only (recommended). Use 0.0.0.0 to expose externally.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Website: 0.0.0.0 = all interfaces. Set to a specific IP to restrict access.
WEBSITE_HOST=0.0.0.0
WEBSITE_PORT=3000
